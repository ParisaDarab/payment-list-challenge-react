# dependencies
node_modules/

# build output
dist/
dist-ssr/

# TypeScript incremental build info — generated by "tsc -b" on every build
*.tsbuildinfo

# test artifacts — regenerated on every run, no reason to commit
coverage/
junit.xml

# environment variables — never commit real or placeholder secrets
.env
.env.local
.env.*.local

# logs
*.log
npm-debug.log*

# editor / OS noise
.vscode/*
!.vscode/extensions.json
.DS_Store
Thumbs.db